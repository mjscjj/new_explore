PORT=8787

# ===== Gemini Live (Google) =====
GEMINI_API_KEY=your-google-api-key
GEMINI_LIVE_MODEL=models/gemini-3.1-flash-live-preview

# ===== 豆包端到端实时语音 (火山引擎) =====
DOUBAO_APP_ID=your-app-id
DOUBAO_ACCESS_TOKEN=your-access-token
DOUBAO_SECRET_KEY=your-secret-key

# ===== Qwen-Audio 实时语音 (阿里云百炼 DashScope) =====
# 北京地域 API Key（qwen-audio-3.0-realtime-* 需选北京地域的 key）
QWEN_API_KEY=sk-your-dashscope-api-key
QWEN_REALTIME_MODEL=qwen-audio-3.0-realtime-plus

# ===== QwebO / Qwen-Omni 全模态实时 (阿里云百炼 DashScope) =====
# 全模态（音频+视觉），支持摄像头。用北京地域 API Key。
QWEBO_API_KEY=sk-your-dashscope-api-key
QWEBO_REALTIME_MODEL=qwen3.5-omni-plus-realtime
