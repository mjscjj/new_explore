**/node_modules/
**/venv/
**/.venv/
**/vendor/

# 构建产物
**/dist/
**/build/
**/out/
**/.next/
**/target/
**/.turbo/
**/*.egg-info/

# 缓存 / 中间产物
**/__pycache__/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.cache/
**/coverage/
**/.git/objects/

